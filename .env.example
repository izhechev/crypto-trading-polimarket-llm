# Groq (free tier — llama-3.3-70b)
GROQ_API_KEY=

# Binance (free, read-only)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Polymarket (free, no key needed for Gamma API)
# CLOB needs key only for trading

# Dune Analytics (free, 2500 credits)
DUNE_API_KEY=

# Tavily AI (optional — improves news catalyst quality for top-10 summaries)
# Free tier: 1,000 searches/month, NO credit card required
# Sign up at app.tavily.com — get your key instantly
# Without this key, falls back to DuckDuckGo (also free, no key needed)
TAVILY_API_KEY=
